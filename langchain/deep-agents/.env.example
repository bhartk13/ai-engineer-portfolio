# LLM (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=auto
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini

# Web research tool
TAVILY_API_KEY=

# Optional observability
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# Agent configuration
WORKSPACE_ROOT=./workspace
RUNS_ROOT=./runs
DEPLOY_PLATFORM=netlify

# Static deploy (Netlify — default free hosting)
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
