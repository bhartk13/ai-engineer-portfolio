# Application
APP_NAME=Text-to-SQL Copilot
APP_ENV=development
LOG_LEVEL=INFO

# Database (app user — read-only for query execution)
DATABASE_URL=postgresql+asyncpg://copilot:changeme@localhost:5433/sales_db

# Admin DB URL for migrations/seeding (read-write, local/dev only)
DATABASE_ADMIN_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/sales_db

# LLM provider: "ollama" (free local) or "groq" (free cloud tier)
LLM_PROVIDER=ollama

# Ollama (default — zero API cost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq (free tier — good for cloud deployment)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Agent limits (keeps LLM cost low)
MAX_SQL_RETRIES=2
MAX_RESULT_ROWS=100
SQL_TIMEOUT_SECONDS=10
MAX_QUESTION_LENGTH=500

# Query cache (skips LLM + DB on repeated questions)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=256

# API
CORS_ORIGINS=*
